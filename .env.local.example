# Supabase (optional — the app works 100% local without these).
# The anon/publishable key is public; access is protected by RLS.
# NEVER put the service_role / secret key here (it must not reach the client).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-ANON-KEY
